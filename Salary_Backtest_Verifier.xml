   <Row><Cell><Data ss:Type="String">Sec123(80C) total</Data></Cell><Cell ss:StyleID="money" ss:Formula="=MIN(R22C2+MIN(R14C2,150000),150000)"><Data ss:Type="Number">0</Data></Cell></Row>
